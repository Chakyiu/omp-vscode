{
  "name": "oh-my-pi-chat",
  "displayName": "OMP Chat",
  "description": "Copilot/Cursor-style chat sidebar for OMP (omp) in VS Code",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chakyiu/omp-vscode"
  },
  "version": "0.3.0",
  "publisher": "ChakyiuLI",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "omp",
    "oh-my-pi",
    "ai",
    "chat",
    "coding-agent"
  ],
  "activationEvents": [
    "onView:ompChat.sidebar",
    "onCommand:ompChat.open",
    "onCommand:ompChat.newChat",
    "onCommand:ompChat.sendSelection",
    "onCommand:ompChat.attachFiles",
    "onCommand:ompChat.attachFolder",
    "onCommand:ompChat.attachMenu",
    "onCommand:ompChat.attachExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ompChat",
          "title": "OMP",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ompChat": [
        {
          "type": "webview",
          "id": "ompChat.sidebar",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "ompChat.open",
        "title": "OMP: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "ompChat.newChat",
        "title": "OMP: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "ompChat.stop",
        "title": "OMP: Stop Generation",
        "icon": "$(debug-stop)"
      },
      {
        "command": "ompChat.sendSelection",
        "title": "OMP: Send Selection to Chat"
      },
      {
        "command": "ompChat.attachCurrentFile",
        "title": "OMP: Attach Current File"
      },
      {
        "command": "ompChat.restartSession",
        "title": "OMP: Restart Session"
      },
      {
        "command": "ompChat.attachFiles",
        "title": "OMP: Attach Files",
        "icon": "$(attach)"
      },
      {
        "command": "ompChat.attachFolder",
        "title": "OMP: Attach Folder",
        "icon": "$(folder)"
      },
      {
        "command": "ompChat.attachMenu",
        "title": "OMP: Attach…",
        "icon": "$(attach)"
      },
      {
        "command": "ompChat.attachExplorer",
        "title": "OMP: Attach to Chat",
        "icon": "$(attach)"
      },
      {
        "command": "ompChat.showToolLog",
        "title": "OMP: Show File Touch Log",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ompChat.newChat",
          "when": "view == ompChat.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "ompChat.stop",
          "when": "view == ompChat.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "ompChat.restartSession",
          "when": "view == ompChat.sidebar",
          "group": "navigation@3"
        },
        {
          "command": "ompChat.attachMenu",
          "when": "view == ompChat.sidebar",
          "group": "navigation@0"
        }
      ],
      "editor/context": [
        {
          "command": "ompChat.sendSelection",
          "when": "editorHasSelection",
          "group": "ompChat@1"
        },
        {
          "command": "ompChat.attachCurrentFile",
          "group": "ompChat@2"
        }
      ],
      "explorer/context": [
        {
          "command": "ompChat.attachExplorer",
          "group": "ompChat@1"
        }
      ]
    },
    "configuration": {
      "title": "OMP Chat",
      "properties": {
        "ompChat.ompPath": {
          "type": "string",
          "default": "omp",
          "description": "Path to the omp executable."
        },
        "ompChat.model": {
          "type": "string",
          "default": "",
          "description": "Optional model override (fuzzy match, e.g. opus, gpt-5.2)."
        },
        "ompChat.thinking": {
          "type": "string",
          "enum": [
            "",
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "max",
            "auto"
          ],
          "default": "",
          "description": "Optional thinking level passed to omp."
        },
        "ompChat.approvalMode": {
          "type": "string",
          "enum": [
            "",
            "always-ask",
            "write",
            "yolo"
          ],
          "default": "",
          "description": "Optional tools.approvalMode override for this session."
        },
        "ompChat.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "Pass --auto-approve to omp (skip approval prompts)."
        },
        "ompChat.continueLastSession": {
          "type": "boolean",
          "default": true,
          "description": "Restore all open omp chat tabs/sessions when the chat bridge starts (survives VS Code restarts/kills). Disable to always start a blank session."
        },
        "ompChat.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra CLI args appended when spawning omp --mode rpc."
        },
        "ompChat.mode": {
          "type": "string",
          "enum": [
            "Agent",
            "Ask",
            "Plan"
          ],
          "default": "Agent",
          "description": "Chat mode shown in the Cursor-style composer."
        },
        "ompChat.displayName": {
          "type": "string",
          "default": "",
          "description": "Optional name used in the greeting (e.g. How can I help you, Alex?)."
        },
        "ompChat.showThinking": {
          "type": "boolean",
          "default": true,
          "description": "Show model thinking blocks in the chat UI."
        },
        "ompChat.logFileTouches": {
          "type": "boolean",
          "default": true,
          "description": "Log edit/write/delete tool calls and touched file paths to the \"OMP File Touches\" output channel."
        }
      }
    },
    "keybindings": [
      {
        "command": "ompChat.open",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      },
      {
        "command": "ompChat.sendSelection",
        "key": "ctrl+shift+'",
        "mac": "cmd+shift+'",
        "when": "editorTextFocus && editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies --allow-missing-repository",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  }
}